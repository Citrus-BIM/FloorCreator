<Window x:Class="FloorCreator.ErrorRoomsDialogWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:FloorCreator"
        mc:Ignorable="d"
        Title="Ошибки генерации пола"
        Height="300" Width="420"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="Resources/citrus.ico"
        WindowStartupLocation="CenterScreen"

        FontFamily="{DynamicResource BaseFont}"
        FontSize="{DynamicResource FontSizeBase}"
        Foreground="{DynamicResource TextBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Language="ru-RU">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FloorCreator;component/CitrusTheme/CitrusTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Не удалось создать полы в следующих помещениях:"
                   Margin="0,0,0,8"/>

        <ListBox x:Name="lstErrorRooms"
                 Grid.Row="1"
                 Margin="0"
                 BorderThickness="1"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Сохранить"
                    Width="110"
                    Height="32"
                    Margin="0,0,8,0"
                    Padding="10,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Закрыть"
                    Width="110"
                    Height="32"
                    Padding="10,0,10,0"
                    Click="CloseButton_Click"
                    Style="{StaticResource ButtonOutline}"/>
        </StackPanel>
    </Grid>
</Window>
