<Window x:Class="FloorCreator.FloorCreatorWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:FloorCreator"
        mc:Ignorable="d"
        Title="Полы"
        Height="400" Width="600"
        MinHeight="400" MinWidth="600" MaxHeight="400"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="Resources/citrus.ico"
        WindowStartupLocation="CenterScreen"
        KeyDown="FloorCreatorWPF_KeyDown"

        FontFamily="{DynamicResource BaseFont}"
        FontSize="{DynamicResource FontSizeBase}"
        Foreground="{DynamicResource TextBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Language="ru-RU">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FloorCreator;component/CitrusTheme/CitrusTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10,5,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхний блок -->
        <GroupBox x:Name="groupBox_FloorCreationOption"
                  Header="Выберите опцию:"
                  Grid.Row="0"
                  Margin="0,0,0,10">
            <StackPanel VerticalAlignment="Top">

                <RadioButton x:Name="rbt_ManualCreation"
                             Content="Создать вручную"
                             Margin="10,5,10,0"
                             Height="20"
                             VerticalContentAlignment="Center"
                             Checked="groupBox_FloorCreationOption_Checked"/>

                <ComboBox x:Name="comboBox_FloorType"
                          Margin="10,5"
                          Height="32"
                          VerticalContentAlignment="Center"
                          IsEditable="True"/>

                <TextBlock x:Name="textBlock"
                           Margin="10,5,10,10"
                           TextWrapping="Wrap"
                           Text='*В свойствах Типа перекрытий, используемых в качестве пола, в параметр "Группа модели" необходимо вписать значение "Пол" или "Полы"'/>

                <RadioButton x:Name="rbt_CreateFromParameter"
                             Content='Создать из параметра "Отделка пола"'
                             Margin="10,10,10,0"
                             Height="20"
                             VerticalContentAlignment="Center"
                             Checked="groupBox_FloorCreationOption_Checked"/>

                <GroupBox x:Name="groupBox_InRooms"
                      Header="В помещениях:"
                      Margin="10,0,10,0"
                      Height="Auto">
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <RadioButton x:Name="rbt_InSelected"
                             Content="Выбранных"
                             IsChecked="True"
                             Margin="10,5,50,5"
                             VerticalContentAlignment="Center"/>

                        <RadioButton x:Name="rbt_InWholeProject"
                             Content="Во всем проекте"
                             Margin="50,5,10,5"
                             VerticalContentAlignment="Center"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </GroupBox>

        <!-- Низ: параметры + кнопки -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Параметры (как было снизу) -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300*"/>
                    <ColumnDefinition Width="300*"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="chk_FillDoorPatches"
                          Content="Заводить пол в дверные проемы"
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          IsChecked="False"
                          Margin="10,0,0,0"/>

                <Label x:Name="label_FloorLevelOffset"
                       Content="Смещение от уровня:"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Width="130"
                       Margin="0,0,120,0"
                       Grid.Column="1"
                       Height="32"
                       Padding="0"
                       VerticalContentAlignment="Center"/>

                <TextBox x:Name="textBox_FloorLevelOffset"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Width="70"
                         Height="32"
                         Text="0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         Padding="10,0,10,0"
                         Grid.Column="1"
                         Margin="0,0,45,0"/>

                <TextBlock x:Name="label_FloorLevelOffsetMM"
                           Text="мм"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Grid.Column="1"/>
            </Grid>

            <!-- Кнопки -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="btn_Ok"
                        Content="Ок"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="0,0,5,0"
                        IsDefault="True"
                        Click="btn_Ok_Click"/>

                <Button x:Name="btn_Cancel"
                        Content="Отмена"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="5,0,0,0"
                        IsCancel="True"
                        Style="{StaticResource ButtonOutline}"
                        Click="btn_Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
